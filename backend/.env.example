# ── FinesseWins backend environment ──────────────────────────────────────────
# Copy to .env and fill in. Anything left blank degrades gracefully (dev mode).

# AI (required for real proposal generation)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-5

# ── Production hardening ─────────────────────────────────────────────────────
# Hide representative SAMPLE listings so users only ever see live opportunities.
FINESSEWINS_HIDE_SAMPLE=1
# Set to 1 only in local dev to turn off per-IP rate limiting.
RATE_LIMIT_DISABLED=0

# SAM.gov opportunity search (optional — uses mock data if blank)
SAM_API_KEY=

# ── Supabase (persistence + auth) ───────────────────────────────────────────
# Project → Settings → API. Use the SERVICE ROLE key on the backend (never ship
# it to the browser). JWT secret is under Settings → API → JWT Settings.
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
SUPABASE_JWT_SECRET=
# SUPABASE_JWT_AUD=authenticated

# ── Email notifications (pick ONE; blank = log to stdout) ────────────────────
# Option A: Resend (recommended)
RESEND_API_KEY=
FINESSEWINS_FROM_EMAIL=FinesseWins <alerts@finessewins.com>
# Option B: SMTP
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
# Fallback recipient for alerts when a tracked row has no notify_email
FINESSEWINS_ALERT_EMAIL=

# ── Stripe billing (optional — checkout falls back if blank) ─────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=          # from `stripe listen` or the Dashboard webhook endpoint
STRIPE_SOLO_PRICE_ID=
STRIPE_PRO_PRICE_ID=
STRIPE_AGENCY_PRICE_ID=
STRIPE_ORG_PRICE_ID=
# Free-tier monthly proposal allowance (before subscribing)
FREE_MONTHLY_LIMIT=2

# ── App wiring ───────────────────────────────────────────────────────────────
FINESSEWINS_APP_URL=https://app.finessewins.com
CORS_ORIGINS=http://localhost:5173,https://app.finessewins.com,https://finessewins.com
# Background monitor cadence
AMENDMENT_INTERVAL_HOURS=6
DEADLINE_INTERVAL_HOURS=12
REMINDER_WINDOW_DAYS=3
# NAICS watch ("Bid Radar") — how often to sweep every bid site. Twice daily.
NAICS_INTERVAL_HOURS=12
