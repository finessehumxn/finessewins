# ── FinesseWins frontend environment (Vite) ──────────────────────────────────
# Copy to .env. If SUPABASE vars are blank, the app runs in no-auth dev mode
# (no login screen) and talks to the local backend via the Vite proxy.

# Supabase project → Settings → API. Use the ANON (public) key here — never the
# service role key in the browser.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Backend origin. Leave blank in dev (Vite proxies /api → localhost:8000).
# In prod set to your deployed API, e.g. https://api.finessewins.com
VITE_API_URL=
